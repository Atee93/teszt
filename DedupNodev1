public List<IDocument> myqueryDocuments(String whereClause, List<String> databaseNames, boolean currentVersionOnly) throws BlueLineException {
 IQueryParameter qParam = null
 try {
 qParam = ds.getClassFactory().getQueryParameterInstance(
 s,
 databaseNames.toArray(new String[0]),
 ds.getClassFactory().getExpressionInstance(whereClause),
 null,
 null
 )

 qParam.setCurrentVersionOnly(currentVersionOnly);
            
 IDocumentHitList hitList = ds.query(qParam, s);
 IDocument[] docs = hitList.getDocumentObjects();
            
 if (docs.length == 0) {
  return Collections.emptyList();
 } else {
  return Arrays.asList(docs);
 }

}

 
 catch (Exception e){
  log.error("Error: {}", e.getMessage())
 }
 finally {
  if (qParam != null){
   qParam.close()
  }
 }
}
        
        
        
        
void traverseNode(INode node, IFolder folder1){

//TOPLEVEL NODES
    if ((node.getType() == FMNodeType.STATIC || node.getType() == FMNodeType.NODESONLY) && node.getParent() == null){

       INodes folder1TopLevelNodes = folder1.getNodes2()
       
       boolean foundTopLevelTargetNode = false;
       
       for (int i = 0; i<folder1TopLevelNodes.getCount();i++){

          if(folder1TopLevelNodes.getItem(i).getName() == node.getName()){
          	foundTopLevelTargetNode = true;

          	log.info("Found Top Level Target node. Name:  {} ",folder1TopLevelNodes.getItem(i).getName() )
          	break;

          	
          	}
       }


       if(!foundTopLevelTargetNode){
       	log.info("NOT FOUND Top level Target node, Creating:  {} ", node.getName())

          folder1TopLevelNodes.addNew(FMNodeType.STATIC).setName(node.getName())
          //!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
          folder1.commit()
       	
       	}
    }



//CHILD NODES
   if (node.getType() == FMNodeType.STATIC && node.getParent() != null){

       INode parentNode = node.getParent()
      
       List<INode>folder1ParentNode = folder1.getNodesByName(parentNode.getName())

       if (folder1ParentNode.size() == 1){

       INodes folder1ParentChildNodes = (INodes)folder1ParentNode.get(0).getChildNodes()
       
       boolean foundTargetNode = false;
       
       for (int i = 0; i < folder1ParentChildNodes.getCount(); i++){
       	
       	if (folder1ParentChildNodes.getItem(i).getName() == node.getName()){
           log.info("Found Target node name {}", node.getName())
           foundTargetNode = true;
           break;
   		
       	}
       	}

       if(!foundTargetNode){

        folder1ParentChildNodes.addNew(FMNodeType.STATIC).setName(node.getName())
        
        //!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
        folder1.commit()
       }

       }

    }


if (node.getType() == FMNodeType.STATIC){

 // Link kiszedese a nodebol

IElements nodeElements = node.getElements()

IDocumentHitList nodeElementsHitList = nodeElements.resolveInformationObjects(VersionIdentifier.CURRENT_VERSION, IRetentionState.ALL, false)

IInformationObject[] nodeInformationobjects = nodeElementsHitList.getInformationObjects()


// NodeID csak akkor lehet meg ha commitoltuk a node letrehozast.

List<INode> targetNodeToLink = folder1.getNodesByName(node.getName())

IElements targetNodeElements = targetNodeToLink.get(0).getElements()

IDocumentHitList targetNodeElementsHitList = targetNodeElements.resolveInformationObjects(VersionIdentifier.CURRENT_VERSION, IRetentionState.ALL, false)
IInformationObject[] targetNodeInformationobjects = targetNodeElementsHitList.getInformationObjects()



for (IInformationObject nodeInformationobject : nodeInformationobjects){
	 
boolean foundLinkInTargetNode = false;

for (IInformationObject targetNodeInformationobject : targetNodeInformationobjects){
	
	
	if (nodeInformationobject.getId() == targetNodeInformationobject.getId()){

          log.info("Az alabbi doc jelen van {} , Ebben a targetnodeban -> {}", targetNodeInformationobject, targetNodeToLink.get(0))
		foundLinkInTargetNode = true
		break;
		
		}

}


if (!foundLinkInTargetNode){
ILink addNewLink = ds.createLink (s, folder1.getId() , targetNodeToLink.get(0), nodeInformationobject.getId())
//!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
addNewLink.commit()
	
}
}
}

    INodes childnodes = (INodes)node.getChildNodes()
    
    for (int i = 0; i < childnodes.getCount();i++){

           
          if (childnodes.getItem(i).getType() == FMNodeType.STATIC){

               log.info("traverse on {}", childnodes.getItem(i).getName())
          	traverseNode(childnodes.getItem(i), folder1)        	

          } 
   }

  
}





        
        
    
